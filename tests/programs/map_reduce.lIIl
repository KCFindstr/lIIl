rm ut.
rm ll.

map << lst | f {
    mk res lol.
    mk len@res 0.
    mk i 0.
    loli i < len@lst {
        mk val [i]@lst.
        mk new_val val >> f.
        res | new_val >> hasu@ll.
        mk i > i.
    }
    (°∀°)ﾉ res.
}

filter << lst | f {
    mk res lol.
    mk len@res 0.
    mk i 0.
    loli i < len@lst {
        mk val [i]@lst.
        mk keep val >> f.
        keep nara res | val >> hasu@ll.
        mk i > i.
    }
    (°∀°)ﾉ res.
}

reduce << lst | f | init {
    mk acc init.
    mk i 0.
    loli i < len@lst {
        mk val [i]@lst.
        mk acc acc | val >> f.
        mk i > i.
    }
    (°∀°)ﾉ acc.
}

double << x {
    (°∀°)ﾉ x * 2.
}

add << a | b {
    (°∀°)ﾉ a + b.
}

is_even << x {
    (°∀°)ﾉ x % 2 = 0.
}

mk lst lol.
lst | 1 >> hasu@ll.
lst | 2 >> hasu@ll.
lst | 3 >> hasu@ll.

<-- Map test
mk mapped lst | double >> map.
len@mapped = 3 | "Mapped list length should be 3." >> assert@ut.
0@mapped = 2 | "0@mapped should be 2." >> assert@ut.
1@mapped = 4 | "1@mapped should be 4." >> assert@ut.
2@mapped = 6 | "2@mapped should be 6." >> assert@ut.

<-- Reduce test
mk sum mapped | add | 0 >> reduce.
sum = 12 | "Sum should be 12." >> assert@ut.

<-- Map-Filter-Reduce Chain test
mk lst2 lol.
lst2 | 1 >> hasu@ll.
lst2 | 2 >> hasu@ll.
lst2 | 3 >> hasu@ll.
lst2 | 4 >> hasu@ll.

mk chain_res (((lst2 | is_even >> filter)
               | double) >> map)
               | add | 0 >> reduce.
chain_res = 12 | "Chain result should be 12." >> assert@ut.
