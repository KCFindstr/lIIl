rm ut.

mk a 1.
a = 1 >> assert@ut.

make a = 2.
a = 2 >> assert@ut.

mk a > 3.
a = 4 >> assert@ut.

mk a < 4.
a = 3 >> assert@ut.

mk a >= 4.
a = 4 >> assert@ut.

mk a <= 3.
a = 3 >> assert@ut.

mk a != 3.
a != 3 >> assert@ut.

<-- Test member increment (fix for greedy parsing bug)
make obj lol.
make val@obj 1.
make val@obj > val@obj.
val@obj = 2 | "Member increment should work." >> assert@ut.
